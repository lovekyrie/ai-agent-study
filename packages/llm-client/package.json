{
  "name": "@ai-agent-study/llm-client",
  "version": "0.1.0",
  "description": "统一的 LLM 客户端，支持多模型、流式响应、结构化输出",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
