{
  "name": "ai-agent-study",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "AI Agent 学习项目 - 从基础到生产级完整实现",
  "author": "",
  "license": "MIT",
  "keywords": [
    "ai",
    "agent",
    "llm",
    "rag",
    "mcp",
    "typescript"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev:backend": "pnpm --filter @ai-agent-study/api dev",
    "dev:frontend": "pnpm --filter @ai-agent-study/frontend dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf node_modules dist backend/packages/*/node_modules backend/stages/*/node_modules backend/projects/*/node_modules backend/apps/*/node_modules frontend/node_modules",
    "typecheck": "tsc --noEmit && pnpm --filter @ai-agent-study/frontend typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.0.0",
    "@types/node": "^22.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^9.10.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
