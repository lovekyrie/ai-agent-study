# Stage 1 环境变量示例

# ---- LLM ----
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
DEFAULT_MODEL=gpt-4o
# 解析为 float，范围 [0, 2]
DEFAULT_TEMPERATURE=0.7
# 解析为整数
DEFAULT_MAX_TOKENS=1000

# ---- 数据库（@ai-agent-study/config schema 校验需要）----
DATABASE_URL=postgresql://user:pass@localhost:5432/agent

# ---- 安全（至少 32 字符）----
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# ---- 日志 ----
LOG_LEVEL=info
LOG_PRETTY=true
