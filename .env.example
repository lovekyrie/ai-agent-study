# LLM Configuration（MiniMax，OpenAI 兼容接口）
OPENAI_API_KEY=your-minimax-api-key-here
OPENAI_API_BASE=https://api.minimaxi.com/v1
DEFAULT_MODEL=MiniMax-M2.7
# 解析为 float，范围 [0, 2]
DEFAULT_TEMPERATURE=0.7
# 解析为整数
DEFAULT_MAX_TOKENS=1000

# Vector Database (Chroma)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIRECTORY=./chroma_data

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Relational Database
DATABASE_URL=postgresql://user:pass@localhost:5432/agent

# Redis
REDIS_URL=redis://localhost:6379

# Application
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# MCP
MCP_SERVER_URL=
MCP_SERVER_TOKEN=

# Security（生产环境必须替换为至少 32 字符的随机串）
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Caching
CACHE_TTL_SECONDS=300

# Feature Flags
ENABLE_TRACING=false
ENABLE_METRICS=false
ENABLE_AUDIT_LOG=false
