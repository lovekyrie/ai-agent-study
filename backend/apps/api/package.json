{
  "name": "@ai-agent-study/api",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Hono API for the AI Agent Study frontend",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/public.js",
  "types": "./dist/public.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-agent-study/config": "workspace:*",
    "@ai-agent-study/llm-client": "workspace:*",
    "@ai-agent-study/server": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
